{
  "name": "english-validator",
  "version": "2.0.2",
  "description": "Detect whether a sentence is English or non-English. Returns true/false with high accuracy using dictionary lookup and trigram analysis.",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c && node -e \"require('fs').writeFileSync('dist/index.mjs', \\\"import cjsModule from './index.cjs';\\nexport const { isEnglish, detectNonEnglishText, matchesDocumentPattern, clearLanguageDetectorCaches } = cjsModule;\\n\\\")\"",
    "test": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.js\"",
    "check": "npm run lint && npm run format:check && npm test",
    "prepublishOnly": "npm run build && npm test",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "english",
    "language-detection",
    "non-english",
    "nlp",
    "text-analysis",
    "language",
    "detector",
    "validator",
    "is-english",
    "sentence-detection",
    "typescript"
  ],
  "author": "nuvayutech",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NuvayuTech/english-validator.git"
  },
  "bugs": {
    "url": "https://github.com/NuvayuTech/english-validator/issues"
  },
  "homepage": "https://github.com/NuvayuTech/english-validator#readme",
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@eslint/js": "^9.39.3",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "babel-jest": "^29.7.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "franc": "^6.2.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "rollup": "^4.24.0",
    "ts-jest": "^29.2.0",
    "tslib": "^2.7.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.56.1"
  }
}
